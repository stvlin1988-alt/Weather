# Copy this file to .env and fill in values
# NEVER commit .env to git

# Flask
SECRET_KEY=change-this-to-a-random-secret-key

# Database (Zeabur PostgreSQL — copy from Zeabur dashboard)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cookie security (set true in production)
SESSION_COOKIE_SECURE=true

# AI — 依序嘗試 Gemini → Ollama → Anthropic
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=
OPENWEATHERMAP_API_KEY=

# Cloudflare R2 (get from R2 dashboard → API Tokens)
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=face-photos
R2_PUBLIC_URL=

# Rate limiting (use Redis URL in production, e.g. redis://localhost:6379/0)
RATELIMIT_STORAGE_URL=memory://

# CORS (comma-separated origins)
ALLOWED_ORIGINS=https://yourapp.zeabur.app
